# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-token
# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Get yours by messaging the bot once — it replies with your ID if unauthorized.
ALLOWED_USER_IDS=

# --- LLM (first configured wins; you only need ONE of these) ---
# FREE (recommended): https://aistudio.google.com/apikey — no credit card needed
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# FREE alternative: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# FREE + fully local/offline: brew install ollama && ollama pull llama3.1
OLLAMA_MODEL=
OLLAMA_URL=http://localhost:11434
# Paid options
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Provider try-order. Groq first keeps Gemini's smaller free quota in reserve.
LLM_PRIORITY=groq,gemini,claude,openrouter,ollama

# --- Indexing ---
# Comma-separated directories to index (relative to $HOME or absolute)
INDEX_DIRS=Desktop,Documents,Downloads,Projects,Pictures
MAX_FILE_SIZE_MB=25
# Re-scan interval in minutes (watchdog also reacts live)
RESCAN_INTERVAL_MIN=60
ENABLE_OCR=true
ENABLE_VOICE=true
# base=fast/English-ok; small=recommended for Hindi/Hinglish voice; medium=best/slow
WHISPER_MODEL=small

# --- Proactive monitoring (zero LLM cost) ---
MONITOR_INTERVAL_MIN=10
ALERT_BATTERY_PCT=20
ALERT_DISK_PCT=90
BACKUP_ENABLED=true
BACKUP_KEEP=7

# --- Cloud relay (optional, run scripts/setup_cloud.sh to fill these) ---
# When set, the bot answers general questions even while this Mac is off.
WORKER_URL=
# Shared secret between the Worker and this Mac's long-poll bridge.
BRIDGE_SECRET=
# Secret token Telegram includes on each webhook call (set on both sides by
# scripts/setup_cloud.sh). Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# --- Dashboard ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8788

# --- Storage ---
DATA_DIR=./data
